# Docker (docker compose up -d)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crud_db

# Homebrew PostgreSQL (brew services start postgresql@18)
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/crud_db

# 阿里云百炼 DashScope API Key（LLM 分析 + 文生图）
DASHSCOPE_API_KEY=sk-your-api-key-here

# Visual Brief 使用的 LLM 模型（如 qwen-plus、qwen-turbo）
LLM_MODEL=qwen-plus

# 文生图模型
IMAGE_MODEL=qwen-image-2.0-pro

# OpenAI API Key（DALL-E 文生图 / GPT Visual Brief）
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 后端日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
